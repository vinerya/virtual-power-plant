# VPP Platform Configuration
# Copy this file to .env and fill in values

# =============================================================================
# Core Settings
# =============================================================================
VPP_ENV=development
VPP_DEBUG=true
VPP_LOG_LEVEL=INFO

# =============================================================================
# API Server
# =============================================================================
VPP_API_HOST=0.0.0.0
VPP_API_PORT=8000
VPP_API_WORKERS=1
VPP_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# =============================================================================
# Security
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
VPP_SECRET_KEY=change-me-to-a-real-secret-key
VPP_JWT_ALGORITHM=HS256
VPP_JWT_EXPIRE_MINUTES=60
VPP_API_KEY_HEADER=X-API-Key

# =============================================================================
# Database
# =============================================================================
# SQLite (development):
VPP_DATABASE_URL=sqlite+aiosqlite:///./vpp.db
# PostgreSQL (production):
# VPP_DATABASE_URL=postgresql+asyncpg://vpp:password@localhost:5432/vpp

# =============================================================================
# Redis (optional - for caching and pub/sub)
# =============================================================================
# VPP_REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Monitoring
# =============================================================================
VPP_METRICS_ENABLED=true
VPP_METRICS_PREFIX=vpp

# =============================================================================
# VPP Configuration
# =============================================================================
VPP_CONFIG_PATH=configs/advanced_vpp_config.yaml
VPP_DEFAULT_TIMEZONE=UTC
